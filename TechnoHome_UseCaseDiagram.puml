@startuml Techno Home - مخطط حالات الاستخدام
' ======================================================
' مخطط حالات الاستخدام الشامل لمشروع تكنو هوم
' بناءً على تحليل نظام Backend وملفات التوثيق
' باستخدام علاقات <<include>> و <<extend>> بشكل أكاديمي صحيح
' ======================================================

' ==== إعدادات المخطط ====
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam shadowing true
skinparam linetype ortho
title \n**📱 منصة تكنو هوم - مخطط حالات الاستخدام الشامل**\n

' ==== الفاعلين (Actors) ====
actor "👤 العميل" as Customer
actor "🔧 الفني المعتمد" as Technician
actor "👨‍💼 المشرف الإداري" as Admin
actor "🧠 نظام الخبير" as ExpertSystem
actor "🤖 ذكاء اصطناعي Gemini" as GeminiAI

' ==== تقسيم حسب الفاعل ====
rectangle "منصة صيانة الأجهزة المنزلية" {

  ' ------------------------------
  ' حالات الاستخدام للعميل
  ' ------------------------------
  usecase "🔐 تسجيل الدخول / تسجيل" as UC1
  usecase "👤 إدارة الملف الشخصي" as UC2
  usecase "📱 إدارة الأجهزة المنزلية" as UC3
  usecase "🛠️ إنشاء طلب صيانة" as UC4
  usecase "🔍 تشخيص العطل" as UC5
  usecase "🔎 البحث عن فني قريب" as UC6
  usecase "📊 متابعة حالة الطلب" as UC7
  usecase "⭐ تقييم الخدمة" as UC8
  usecase "💵 إدارة المحفظة والدفع" as UC9
  usecase "📨 استلام الإشعارات" as UC10

  ' ------------------------------
  ' حالات الاستخدام للفني
  ' ------------------------------
  usecase "🔐 تسجيل الدخول" as UC11
  usecase "📝 إدارة ملف الفني" as UC12
  usecase "📄 رفع وثائق التحقق" as UC13
  usecase "📬 عرض طلبات الصيانة القريبة" as UC14
  usecase "✅ قبول طلب الصيانة" as UC15
  usecase "🚗 تحديث حالة الرحلة" as UC16
  usecase "🔧 تنفيذ عملية الصيانة" as UC17
  usecase "💰 إدارة المحفظة والعمولات" as UC18
  usecase "🗺️ تحديث الموقع الجغرافي" as UC19

  ' ------------------------------
  ' حالات الاستخدام للمشرف الإداري
  ' ------------------------------
  usecase "🔐 تسجيل الدخول لوحة التحكم" as UC20
  usecase "👥 إدارة حسابات المستخدمين" as UC21
  usecase "✅ الموافقة على طلبات الفنيين" as UC22
  usecase "📋 إدارة طلبات الصيانة" as UC23
  usecase "🏷️ إدارة العلامات التجارية" as UC24
  usecase "📦 إدارة أنواع الأجهزة" as UC25
  usecase "🧠 بناء شجرة التشخيص" as UC26
  usecase "📊 عرض الإحصائيات والتقارير" as UC27
  usecase "📤 تصدير التقارير المالية" as UC28
  usecase "⚙️ إدارة إعدادات النظام" as UC29

  ' ------------------------------
  ' حالات الاستخدام للنظام والذكاء
  ' ------------------------------
  usecase "🌳 منظومة التشخيص منطقي" as UC30
  usecase "🔮 تحليل متقدم بالذكاء الاصطناعي" as UC31
  usecase "🧪 مطابقة رموز الأعطال" as UC32
  usecase "📚 بحث بالوصف النصي" as UC33
  usecase "📢 نظام الإشعارات الذكي" as UC34
}

' ======================================================
' ==== علاقات الفاعلين مع حالات الاستخدام ====
' ======================================================

' العميل
Customer --> UC1
Customer --> UC2
Customer --> UC3
Customer --> UC4
Customer --> UC5
Customer --> UC6
Customer --> UC7
Customer --> UC8
Customer --> UC9
Customer --> UC10

' الفني
Technician --> UC11
Technician --> UC12
Technician --> UC13
Technician --> UC14
Technician --> UC15
Technician --> UC16
Technician --> UC17
Technician --> UC18
Technician --> UC19

' المشرف
Admin --> UC20
Admin --> UC21
Admin --> UC22
Admin --> UC23
Admin --> UC24
Admin --> UC25
Admin --> UC26
Admin --> UC27
Admin --> UC28
Admin --> UC29

' النظام الخبير
ExpertSystem --> UC30
ExpertSystem --> UC32
ExpertSystem --> UC33

' ذكاء اصطناعي جيميناي
GeminiAI --> UC31

' ======================================================
' ==== علاقات <<include>> (الاحتواء) ====
' يتم تنفيذها دائماً عند استدعاء الحالة الأساسية
' ======================================================

UC4 -[dashed]-> UC5 : <<include>>
UC4 -[dashed]-> UC6 : <<include>>
UC4 -[dashed]-> UC10 : <<include>>

UC5 -[dashed]-> UC30 : <<include>>

UC15 -[dashed]-> UC18 : <<include>>
UC15 -[dashed]-> UC10 : <<include>>

UC22 -[dashed]-> UC10 : <<include>>
UC22 -[dashed]-> UC34 : <<include>>

' ======================================================
' ==== علاقات <<extend>> (التمديد) ====
' اختيارية ويتم تنفيذها في حالات معينة فقط
' ======================================================

UC5 -[dashed,northern-> UC31 : <<extend>>
note right of UC31
  يتم استدعاء الذكاء الاصطناعي فقط عندما:
  • لا يتوفر حل في قاعدة البيانات المحلية
  • يطلب المستخدم تحليلاً متقدماً
end note

UC30 -[dashed]-> UC32 : <<extend>>
UC30 -[dashed]-> UC33 : <<extend>>

UC27 -[dashed]-> UC28 : <<extend>>

UC14 -[dashed]-> UC34 : <<extend>>

' ======================================================
' ==== علاقات الارتباط بين حالات الاستخدام ====
' ======================================================

UC6 <.. UC19 : يعتمد على

UC10 <.. UC34 : يستخدم

UC30 <.. UC26 : تم بناؤه بواسطة

UC31 <.. UC5 : يستدعي عند الحاجة

note "ملاحظة:\nتم تجاهل وظائف OCR وفقاً لمتطلباتك\nتم التركيز فقط على نظام الخبير المنطقي وذكاء جيميناي" as N1 at 100, 140

@enduml